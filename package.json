{
  "name": "bmo-atlas",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "clean": "rimraf dist .angular",
    "kill-ports": "node -e \"const k=require('kill-port');[4200,4201,4202,4203].forEach(p=>k(p).catch(()=>{}))\"",
    "dev": "npm run kill-ports && npm run clean && concurrently --kill-others -n dashboard,settings,stocks,shell -c blue,magenta,yellow,green \"npm run start:dashboard\" \"npm run start:settings\" \"npm run start:stocks\" \"npm run start:atlas\"",
    "start": "ng serve atlas",
    "start:atlas": "ng serve atlas",
    "start:dashboard": "ng serve mfe-dashboard",
    "start:settings": "ng serve mfe-settings",
    "start:stocks": "ng serve mfe-stocks",
    "build": "ng build atlas && ng build mfe-dashboard && ng build mfe-settings && ng build mfe-stocks",
    "build:atlas": "ng build atlas",
    "build:dashboard": "ng build mfe-dashboard",
    "build:settings": "ng build mfe-settings",
    "build:stocks": "ng build mfe-stocks",
    "test": "ng test atlas --browsers=chromium",
    "test:once": "ng test atlas --watch=false --browsers=chromium",
    "test:coverage": "ng test atlas --watch=false --browsers=chromium --coverage && start coverage/index.html",
    "test:ci": "ng test atlas --watch=false --browsers=chromium --headless"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular-architects/native-federation": "^21.2.3",
    "@angular/animations": "^21.2.13",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "es-module-shims": "^2.8.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "@oxc-parser/binding-win32-x64-msvc": "^0.131.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.2.1",
    "jsdom": "^28.0.0",
    "kill-port": "^2.0.1",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.2",
    "vitest": "^4.1.0"
  }
}
